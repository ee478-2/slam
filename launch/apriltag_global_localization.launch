<?xml version="1.0"?>
<!--
  Publish global_map -> RTAB local map using visible AprilTag signboards.

  Inputs:
    - /tf from RTAB-Map and apriltag_ros bundle detections
    - config/global_map.yaml signboard poses

  Outputs:
    - TF: global_frame -> rtabmap_frame
    - /global_localization/robot_pose in global_frame
    - /global_localization/selected_tag diagnostic JSON
-->
<launch>
  <arg name="global_map_yaml" default="$(find slam)/config/global_map.yaml"/>
  <arg name="global_frame" default="global_map"/>
  <arg name="rtabmap_frame" default="map"/>
  <arg name="base_frame" default="base_link"/>
  <arg name="tag_detections_topic" default="/tag_detections"/>
  <arg name="publish_hz" default="20.0"/>
  <arg name="lookup_timeout_s" default="0.02"/>
  <arg name="max_tag_age_s" default="0.5"/>
  <arg name="max_tag_distance_m" default="2.0"/>
  <arg name="max_tag_normal_tilt_deg" default="45.0"/>
  <arg name="min_stable_frames" default="3"/>
  <arg name="smoothing_window_size" default="5"/>
  <arg name="stable_max_frame_gap_s" default="0.35"/>
  <arg name="hold_last_transform" default="true"/>
  <arg name="constrain_to_planar" default="true"/>
  <arg name="apply_legacy_orientation_correction" default="true"/>
  <!-- Keep YOLO store detections as soft RTAB landmarks by default. Enabling this
       makes YOLO store IDs 1001..1008 hard candidates for global_map->map. -->
  <arg name="enable_yolo_store_anchors" default="false"/>
  <arg name="yolo_store_tag_id_base" default="1000"/>
  <arg name="yolo_store_class_start" default="1"/>
  <arg name="yolo_store_default_z" default="0.365"/>
  <arg name="yolo_store_yaw_offset" default="0.0"/>

  <node pkg="slam" type="apriltag_global_localizer.py"
        name="apriltag_global_localizer" output="screen">
    <param name="global_map_yaml" value="$(arg global_map_yaml)"/>
    <param name="global_frame" value="$(arg global_frame)"/>
    <param name="rtabmap_frame" value="$(arg rtabmap_frame)"/>
    <param name="base_frame" value="$(arg base_frame)"/>
    <param name="tag_detections_topic" value="$(arg tag_detections_topic)"/>
    <param name="publish_hz" value="$(arg publish_hz)"/>
    <param name="lookup_timeout_s" value="$(arg lookup_timeout_s)"/>
    <param name="max_tag_age_s" value="$(arg max_tag_age_s)"/>
    <param name="max_tag_distance_m" value="$(arg max_tag_distance_m)"/>
    <param name="max_tag_normal_tilt_deg" value="$(arg max_tag_normal_tilt_deg)"/>
    <param name="min_stable_frames" value="$(arg min_stable_frames)"/>
    <param name="smoothing_window_size" value="$(arg smoothing_window_size)"/>
    <param name="stable_max_frame_gap_s" value="$(arg stable_max_frame_gap_s)"/>
    <param name="hold_last_transform" type="bool" value="$(arg hold_last_transform)"/>
    <param name="constrain_to_planar" type="bool" value="$(arg constrain_to_planar)"/>
    <param name="apply_legacy_orientation_correction" type="bool"
           value="$(arg apply_legacy_orientation_correction)"/>
    <param name="enable_yolo_store_anchors" type="bool" value="$(arg enable_yolo_store_anchors)"/>
    <param name="yolo_store_tag_id_base" value="$(arg yolo_store_tag_id_base)"/>
    <param name="yolo_store_class_start" value="$(arg yolo_store_class_start)"/>
    <param name="yolo_store_default_z" value="$(arg yolo_store_default_z)"/>
    <param name="yolo_store_yaw_offset" value="$(arg yolo_store_yaw_offset)"/>
  </node>
</launch>
