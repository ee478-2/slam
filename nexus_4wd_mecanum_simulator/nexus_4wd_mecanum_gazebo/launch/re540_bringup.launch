<?xml version="1.0"?>
<!--
  re540_bringup.launch — Step 2 of A4 Topic 2.

  Loads the re540_final_map world, spawns one nexus_4wd_mecanum robot with
  its RealSense camera, and starts robot_state_publisher. No autonomy.
  Verify with:
    rostopic hz /camera/color/image_raw   # expect >= 15 Hz
    rostopic echo -n1 /gazebo/model_states
-->
<launch>
  <arg name="use_sim_time" default="true"/>
  <arg name="gui"          default="true"/>
  <arg name="paused"       default="false"/>
  <arg name="world_name"   default="$(find slam)/re540_final_map/worlds/final_map.world"/>
  <arg name="pose_x"       default="0.0"/>
  <arg name="pose_y"       default="0.0"/>
  <arg name="pose_z"       default="0.1"/>

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="debug"         value="0"/>
    <arg name="gui"           value="$(arg gui)"/>
    <arg name="use_sim_time"  value="$(arg use_sim_time)"/>
    <arg name="world_name"    value="$(arg world_name)"/>
    <arg name="paused"        value="$(arg paused)"/>
    <arg name="verbose"       value="true"/>
  </include>

  <!-- Load robot description (publishes URDF + JointState + TF) -->
  <include file="$(find slam)/nexus_4wd_mecanum_simulator/nexus_4wd_mecanum_description/launch/nexus_4wd_mecanum_description.launch"/>

  <!-- Spawn the robot in the re540 world -->
  <node name="urdf_spawner" pkg="gazebo_ros" type="spawn_model"
        args="-urdf -model nexus_4wd_mecanum -param robot_description
              -x $(arg pose_x) -y $(arg pose_y) -z $(arg pose_z)"
        output="screen"/>
</launch>
