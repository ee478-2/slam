Panels:
  - Class: rviz/Displays
    Help Height: 80
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Mission map + status1
        - /RTAB-Map1
        - /AprilTag recognition1
        - /Inventory / grasp1
      Splitter Ratio: 0.5
    Tree Height: 720
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Name: Time
    SyncMode: 0
    SyncSource: ""
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.55
      Cell Size: 0.5
      Class: rviz/Grid
      Color: 120; 124; 130
      Enabled: true
      Line Style:
        Line Width: 0.029999999329447746
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 14
      Reference Frame: <Fixed Frame>
      Value: true
    - Class: rviz/TF
      Enabled: true
      Frame Timeout: 15
      Frames:
        All Enabled: true
      Marker Alpha: 1
      Marker Scale: 0.35
      Name: TF
      Show Arrows: false
      Show Axes: true
      Show Names: true
      Tree:
        {}
      Update Interval: 0
      Value: true
    - Class: rviz/Group
      Displays:
        - Class: rviz/MarkerArray
          Enabled: true
          Marker Topic: /mission/markers
          Name: Global map / inventory markers
          Namespaces:
            agent_target: true
            agent_target_label: true
            mission_status: true
            needed_store_highlight: true
            robot_pose: true
            robot_pose_label: true
            robot_to_target: true
            signboard_labels: true
            signboards: true
            store_labels: true
            store_visit_targets: true
            storefronts: true
            visible_signboard_labels: true
            visible_signboards: true
          Queue Size: 100
          Value: true
        - Class: rviz/MarkerArray
          Enabled: false
          Marker Topic: /llm_agent/rviz_markers
          Name: LLM agent debug markers
          Queue Size: 100
          Value: false
      Enabled: true
      Name: Mission map + status
    - Class: rviz/Group
      Displays:
        - Alpha: 1
          Buffer Length: 1
          Class: rviz/Path
          Color: 25; 255; 95
          Enabled: true
          Line Style: Lines
          Name: RTAB-Map trajectory
          Queue Size: 10
          Topic: /rtabmap/mapPath
          Unreliable: false
          Value: true
        - Angle Tolerance: 0.10000000149011612
          Class: rviz/Odometry
          Covariance:
            Orientation:
              Alpha: 0.5
              Color: 255; 255; 127
              Color Style: Unique
              Frame: Local
              Offset: 1
              Scale: 1
              Value: false
            Position:
              Alpha: 0.30000001192092896
              Color: 204; 51; 204
              Scale: 1
              Value: false
            Value: false
          Enabled: true
          Keep: 1
          Name: /odom pose
          Position Tolerance: 0.10000000149011612
          Queue Size: 10
          Shape:
            Alpha: 1
            Axes Length: 0.36000001430511475
            Axes Radius: 0.02500000037252903
            Color: 255; 40; 40
            Head Length: 0.10000000149011612
            Head Radius: 0.05000000074505806
            Shaft Length: 0.30000001192092896
            Shaft Radius: 0.02500000037252903
            Value: Axes
          Topic: /odom
          Unreliable: false
          Value: true
        - Alpha: 0.75
          Autocompute Intensity Bounds: true
          Autocompute Value Bounds:
            Max Value: 10
            Min Value: -10
            Value: true
          Axis: Z
          Channel Name: rgb
          Class: rviz/PointCloud2
          Color: 255; 255; 255
          Color Transformer: RGB8
          Decay Time: 0
          Enabled: false
          Invert Rainbow: false
          Max Color: 255; 255; 255
          Min Color: 0; 0; 0
          Name: RTAB-Map cloud map
          Position Transformer: XYZ
          Queue Size: 10
          Selectable: true
          Size (Pixels): 2
          Size (m): 0.009999999776482582
          Style: Points
          Topic: /rtabmap/cloud_map
          Unreliable: false
          Use Fixed Frame: true
          Use rainbow: true
          Value: false
      Enabled: true
      Name: RTAB-Map
    - Class: rviz/Group
      Displays:
        - Alpha: 1
          Arrow Length: 0.30000001192092896
          Axes Length: 0.4000000059604645
          Axes Radius: 0.05000000074505806
          Class: rviz/PoseArray
          Color: 255; 36; 0
          Enabled: true
          Head Length: 0.07000000029802322
          Head Radius: 0.029999999329447746
          Name: RTAB-Map tag landmarks
          Queue Size: 10
          Shaft Length: 0.12999999523162842
          Shaft Radius: 0.009999999776482582
          Shape: Axes
          Topic: /rtabmap/landmarks
          Unreliable: false
          Value: true
        - Class: rviz/Image
          Enabled: true
          Image Topic: /tag_detections_image
          Max Value: 1
          Median window: 5
          Min Value: 0
          Name: AprilTag image
          Normalize Range: true
          Queue Size: 2
          Transport Hint: raw
          Unreliable: false
          Value: true
        - Class: rviz/Image
          Enabled: true
          Image Topic: /signboards/detections_image
          Max Value: 1
          Median window: 5
          Min Value: 0
          Name: Signboard semantic image
          Normalize Range: true
          Queue Size: 2
          Transport Hint: raw
          Unreliable: false
          Value: true
      Enabled: true
      Name: AprilTag recognition
    - Class: rviz/Group
      Displays:
        - Class: rviz/Image
          Enabled: true
          Image Topic: /detected_objects/debug_image
          Max Value: 1
          Median window: 5
          Min Value: 0
          Name: YOLO object image
          Normalize Range: true
          Queue Size: 2
          Transport Hint: raw
          Unreliable: false
          Value: true
        - Alpha: 1
          Class: rviz/PointStamped
          Color: 255; 185; 0
          Enabled: true
          History Length: 10
          Name: Detected object points
          Queue Size: 10
          Radius: 0.03500000014901161
          Topic: /detected_object_positions_base
          Unreliable: false
          Value: true
        - Alpha: 1
          Class: rviz/PointStamped
          Color: 255; 40; 40
          Enabled: true
          History Length: 5
          Name: Selected grasp target
          Queue Size: 10
          Radius: 0.04500000178813934
          Topic: /grasp_controller/selected_target
          Unreliable: false
          Value: true
        - Alpha: 1
          Class: rviz/PointStamped
          Color: 80; 220; 255
          Enabled: true
          History Length: 5
          Name: Pregrasp target
          Queue Size: 10
          Radius: 0.03500000014901161
          Topic: /grasp_controller/pregrasp_target
          Unreliable: false
          Value: true
        - Alpha: 1
          Class: rviz/PointStamped
          Color: 255; 255; 255
          Enabled: true
          History Length: 5
          Name: Final grasp target
          Queue Size: 10
          Radius: 0.03500000014901161
          Topic: /grasp_controller/grasp_target
          Unreliable: false
          Value: true
      Enabled: true
      Name: Inventory / grasp
    - Class: rviz/Group
      Displays:
        - Alpha: 0.65
          Autocompute Intensity Bounds: true
          Autocompute Value Bounds:
            Max Value: 10
            Min Value: -10
            Value: true
          Axis: Z
          Channel Name: rgb
          Class: rviz/PointCloud2
          Color: 255; 255; 255
          Color Transformer: RGB8
          Decay Time: 0
          Enabled: false
          Invert Rainbow: false
          Max Color: 255; 255; 255
          Min Color: 0; 0; 0
          Name: Raw RealSense cloud
          Position Transformer: XYZ
          Queue Size: 10
          Selectable: true
          Size (Pixels): 2
          Size (m): 0.007000000216066837
          Style: Points
          Topic: /camera/depth/color/points
          Unreliable: false
          Use Fixed Frame: true
          Use rainbow: true
          Value: false
      Enabled: true
      Name: Optional raw sensors
  Enabled: true
  Global Options:
    Background Color: 36; 38; 42
    Default Light: true
    Fixed Frame: map
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz/Interact
      Hide Inactive Objects: true
    - Class: rviz/MoveCamera
    - Class: rviz/Select
    - Class: rviz/FocusCamera
    - Class: rviz/Measure
  Value: true
  Views:
    Current:
      Angle: 0
      Class: rviz/TopDownOrtho
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.05999999865889549
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.009999999776482582
      Scale: 125
      Target Frame: <Fixed Frame>
      X: 0
      Y: -0.55
    Saved: ~
Window Geometry:
  Displays:
    collapsed: false
  Height: 980
  Hide Left Dock: false
  Hide Right Dock: false
  Inventory / grasp:
    collapsed: false
  Signboard semantic image:
    collapsed: false
  Width: 1500
  X: 80
  Y: 27
